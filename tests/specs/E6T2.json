          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "ships:c:0:0" },
        "expect": [
          { "method": "editMessageText" },
          { "method": "editMessageText" },
          { "method": "answerCallbackQuery" }
        ]
      },
      {
        "send": { "callback": "ships:autoplace" },
