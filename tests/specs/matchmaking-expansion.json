[
  {
    "name": "/rmatch starts rating-based matchmaking with initial window",
    "steps": [
      {
        "send": { "text": "/rmatch" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "Searching for opponent...\nRating: 1200\nRating window: ±100" }
          }
        ]
      }
    ]
  },
  {
    "name": "mm:wait shows current search status with window",
    "steps": [
      {
        "send": { "text": "/rmatch" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "mm:wait", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "Still searching...\nRating: 1200\nRating window: ±100 (no expansions yet)\nElapsed: ~0s" }
          }
        ]
      }
    ]
  },
  {
    "name": "mm:friend exits matchmaking and shows invite link",
    "steps": [
      {
        "send": { "text": "/rmatch" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "mm:friend", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "Matchmaking cancelled.\n\nShare this link with a friend to play:\nhttps://t.me/test_bot?start=invite1" }
          }
        ]
      }
    ]
  },
  {
    "name": "mm:wait with no active session shows appropriate message",
    "steps": [
      {
        "send": { "callback": "mm:wait", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "No active matchmaking search. Use /rmatch to start." }
          }
        ]
      }
    ]
  },
  {
    "name": "mm:wait after 15s elapsed expands window to ±200 with 1 expansion",
    "steps": [
      {
        "send": { "text": "/rmatch 15" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "mm:wait", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "Still searching...\nRating: 1200\nRating window: ±200 (1 expansions)\nElapsed: ~15s" }
          }
        ]
      }
    ]
  },
  {
    "name": "mm:wait after 30s elapsed expands window to ±300 with 2 expansions",
    "steps": [
      {
        "send": { "text": "/rmatch 30" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "mm:wait", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "Still searching...\nRating: 1200\nRating window: ±300 (2 expansions)\nElapsed: ~30s" }
          }
        ]
      }
    ]
  },
  {
    "name": "/rmatch with 45s simulates deep expansion (±400, 3 expansions)",
    "steps": [
      {
        "send": { "text": "/rmatch 45" },
        "expect": [{ "method": "sendMessage" }]
      },
      {
        "send": { "callback": "mm:wait", "messageId": 1 },
        "expect": [
          { "method": "answerCallbackQuery" },
          {
            "method": "editMessageText",
            "payload": { "text": "Still searching...\nRating: 1200\nRating window: ±400 (3 expansions)\nElapsed: ~45s" }
          }
        ]
      }
    ]
  }
]